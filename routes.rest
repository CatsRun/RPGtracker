### CHARACTERS

# Get all characters
GET http://localhost:3000/api/characters

###

# Get a character by ID
GET http://localhost:3000/api/characters/69b2d89c9914a92d17da8cc7

###

# POST create character
POST http://localhost:3000/api/characters
Content-Type: application/json

{
  "name": "Luna",
  "friendshipLevel": 2,
  "dailySchedule": ["morning: shop", "afternoon: plaza"],
  "unlockedEvents": []
}

###

# PUT update character
PUT http://localhost:3000/api/characters/69acecc478125971b78cae4d
Content-Type: application/json

{
  "friendshipLevel": 3
}

###

# DELETE character
DELETE http://localhost:3000/api/characters/69acecc478125971b78cae4d

